          <div class="sq-num">SQ6</div>
          <div class="sq-text">Have you returned an item to a Next store in the past 24 months?</div>
          <div class="sq-options">
            <div class="sq-opt">Yes <span class="tag tag-accept">[Must Accept]</span></div>
            <div class="sq-opt">No <span class="tag tag-reject">[Reject — returns experience is a critical research area]</span></div>
          </div>
        </div>

